# @ngrx/signals@21 declares a peer of @angular/core@^21, but this project runs
# Angular 22. @ngrx/signals only uses the stable signals API (signal/computed/
# inject/effect), so it works at runtime on Angular 22 — the conflict is purely
# npm's peer-dependency check. Until an Angular-22-targeting NgRx ships, opt out
# of the strict check so `npm ci` (CI + deploy) resolves the same way local does.
legacy-peer-deps=true
